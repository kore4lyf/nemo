{
  "name": "nemo",
  "version": "0.1.0",
  "description": "Discord project manager bot — AI agent powered by LangChain",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "test": "node --test src/tests/tools.test.js src/tests/behavior.test.js src/tests/api.test.js",
    "test:adversarial": "NODE_ENV=test node --test src/tests/adversarial-*.test.js",
    "test:all": "NODE_ENV=test node --test src/tests/*.test.js"
  },
  "keywords": [
    "discord",
    "bot",
    "langchain",
    "ai-agent",
    "project-manager"
  ],
  "author": "Korede Faleye",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/openai": "^1.5.3",
    "async-retry": "^1.3.3",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "log4js": "^6.9.1",
    "p-queue": "^9.3.1",
    "zod": "^4.4.3"
  }
}
